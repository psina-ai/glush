# =========================================
# .gitignore для Unity 6.x проекта
# =========================================

# Папки, которые Unity генерирует автоматически.
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Пакетные штуки
[Aa]ssets/[Aa]ssetStoreTools*
[Aa]ssets/[Pp]lugins/[Ss]teamworks/
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# Автогенерированные файлы для IDE
.vs/
.vscode/
.idea/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Файлы сборок Unity
*.apk
*.aab
*.ipa
*.unitypackage
*.app

# Специфичное для платформ
crashlytics-build.properties

# Ассеты Kilo Code / AI кэшей
.kilo/
.kilocode/

# Системные файлы
.DS_Store
Thumbs.db
desktop.ini

# Локальные секреты (важно! туда попадут API-ключи если случайно)
*.env
secrets/
*.local

# Backup files
*.bak
*.backup